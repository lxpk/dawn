{% doc %}
  @prompt
    Create a custom catering request form block. IMPORTANT: The form must use Shopify's contact form type exactly like this: {% form 'contact' %} ... {% endform %}. The form should include these fields: Name (input text), Email (input email), Phone Number (input text), Company Name (input text), Company Address (input text), Event Date (input date), Event Type (input text), Number of Guests (input number), and Message/Additional Details (textarea). Include a submit button labeled "Submit Catering Request". Style it professionally to match the store theme.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}
 
{% style %}
  .ai-catering-form-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    margin: 0 auto;
    padding: {{ block.settings.form_padding }}px;
    background-color: {{ block.settings.background_color }};
    border-radius: {{ block.settings.border_radius }}px;
  }

  .ai-catering-form__heading-{{ ai_gen_id }} {
    margin: 0 0 12px;
    font-size: {{ block.settings.heading_size }}px;
    color: {{ block.settings.text_color }};
    text-align: {{ block.settings.text_alignment }};
  }

  .ai-catering-form__description-{{ ai_gen_id }} {
    margin: 0 0 32px;
    font-size: {{ block.settings.description_size }}px;
    color: {{ block.settings.text_color }};
    text-align: {{ block.settings.text_alignment }};
  }

  .ai-catering-form__fields-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .ai-catering-form__row-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
  }

  .ai-catering-form__field-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .ai-catering-form__label-{{ ai_gen_id }} {
    font-size: 14px;
    font-weight: 600;
    color: {{ block.settings.text_color }};
  }

  .ai-catering-form__required-{{ ai_gen_id }} {
    color: {{ block.settings.error_color }};
  }

  .ai-catering-form__input-{{ ai_gen_id }},
  .ai-catering-form__textarea-{{ ai_gen_id }} {
    padding: 12px 16px;
    font-size: 14px;
    border: 1px solid {{ block.settings.input_border_color }};
    border-radius: {{ block.settings.input_border_radius }}px;
    background-color: {{ block.settings.input_background_color }};
    color: {{ block.settings.text_color }};
    font-family: inherit;
  }

  .ai-catering-form__input-{{ ai_gen_id }}:focus,
  .ai-catering-form__textarea-{{ ai_gen_id }}:focus {
    outline: 2px solid {{ block.settings.button_color }};
    outline-offset: 2px;
  }

  .ai-catering-form__textarea-{{ ai_gen_id }} {
    min-height: 120px;
    resize: vertical;
  }

  .ai-catering-form__button-{{ ai_gen_id }} {
    padding: 16px 32px;
    font-size: 16px;
    font-weight: 600;
    background-color: {{ block.settings.button_color }};
    color: {{ block.settings.button_text_color }};
    border: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    cursor: pointer;
    transition: background-color 0.3s ease;
    width: 100%;
  }

  .ai-catering-form__button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_color }};
  }

  .ai-catering-form__success-{{ ai_gen_id }} {
    padding: 16px;
    margin-bottom: 20px;
    background-color: {{ block.settings.success_bg_color }};
    color: {{ block.settings.success_text_color }};
    border-radius: {{ block.settings.input_border_radius }}px;
    font-size: 14px;
  }

  .ai-catering-form__error-{{ ai_gen_id }} {
    padding: 16px;
    margin-bottom: 20px;
    background-color: {{ block.settings.error_bg_color }};
    color: {{ block.settings.error_color }};
    border-radius: {{ block.settings.input_border_radius }}px;
    font-size: 14px;
  }

  @media screen and (max-width: 749px) {
    .ai-catering-form__row-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
    }

    .ai-catering-form-{{ ai_gen_id }} {
      width: 100%;
    }
  }
{% endstyle %}

<catering-form-{{ ai_gen_id }} class="ai-catering-form-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  {% if block.settings.heading != blank %}
    <h2 class="ai-catering-form__heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
  {% endif %}

  {% if block.settings.description != blank %}
    <div class="ai-catering-form__description-{{ ai_gen_id }}">{{ block.settings.description }}</div>
  {% endif %}

  {% form 'contact' %}
    {% if form.posted_successfully? %}
      <div class="ai-catering-form__success-{{ ai_gen_id }}" id="ai-catering-form-success-{{ ai_gen_id }}">
        {{ block.settings.success_message }}
      </div>
    {% endif %}

    {% if form.errors %}
      <div class="ai-catering-form__error-{{ ai_gen_id }}" id="ai-catering-form-error-{{ ai_gen_id }}">
        <p>{{ block.settings.error_message }}</p>
        {% for field in form.errors %}
          <p>{{ field | capitalize }} {{ form.errors.messages[field] }}</p>
        {% endfor %}
      </div>
    {% endif %}

    <input type="hidden" name="contact[form_type]" value="Catering Request">

    <div class="ai-catering-form__fields-{{ ai_gen_id }}">
      <div class="ai-catering-form__row-{{ ai_gen_id }}">
        <div class="ai-catering-form__field-{{ ai_gen_id }}">
          <label for="ai-catering-name-{{ ai_gen_id }}" class="ai-catering-form__label-{{ ai_gen_id }}">
            Name <span class="ai-catering-form__required-{{ ai_gen_id }}">*</span>
          </label>
          <input
            type="text"
            id="ai-catering-name-{{ ai_gen_id }}"
            name="contact[name]"
            class="ai-catering-form__input-{{ ai_gen_id }}"
            required
            aria-required="true"
            {% if form.errors %}
              {% if form.errors contains 'name' %}
                aria-invalid="true"
                aria-describedby="ai-catering-form-error-{{ ai_gen_id }}"
              {% endif %}
            {% endif %}
          >
        </div>

        <div class="ai-catering-form__field-{{ ai_gen_id }}">
          <label for="ai-catering-email-{{ ai_gen_id }}" class="ai-catering-form__label-{{ ai_gen_id }}">
            Email <span class="ai-catering-form__required-{{ ai_gen_id }}">*</span>
          </label>
          <input
            type="email"
            id="ai-catering-email-{{ ai_gen_id }}"
            name="contact[email]"
            class="ai-catering-form__input-{{ ai_gen_id }}"
            required
            aria-required="true"
            autocomplete="email"
            {% if form.errors %}
              {% if form.errors contains 'email' %}
                aria-invalid="true"
                aria-describedby="ai-catering-form-error-{{ ai_gen_id }}"
              {% endif %}
            {% endif %}
          >
        </div>
      </div>

      <div class="ai-catering-form__row-{{ ai_gen_id }}">
        <div class="ai-catering-form__field-{{ ai_gen_id }}">
          <label for="ai-catering-phone-{{ ai_gen_id }}" class="ai-catering-form__label-{{ ai_gen_id }}">
            Phone Number <span class="ai-catering-form__required-{{ ai_gen_id }}">*</span>
          </label>
          <input
            type="text"
            id="ai-catering-phone-{{ ai_gen_id }}"
            name="contact[phone]"
            class="ai-catering-form__input-{{ ai_gen_id }}"
            required
            aria-required="true"
            autocomplete="tel"
          >
        </div>

        <div class="ai-catering-form__field-{{ ai_gen_id }}">
          <label for="ai-catering-company-{{ ai_gen_id }}" class="ai-catering-form__label-{{ ai_gen_id }}">
            Company Name
          </label>
          <input
            type="text"
            id="ai-catering-company-{{ ai_gen_id }}"
            name="contact[company]"
            class="ai-catering-form__input-{{ ai_gen_id }}"
          >
        </div>
      </div>

      <div class="ai-catering-form__field-{{ ai_gen_id }}">
        <label for="ai-catering-address-{{ ai_gen_id }}" class="ai-catering-form__label-{{ ai_gen_id }}">
          Company Address
        </label>
        <input
          type="text"
          id="ai-catering-address-{{ ai_gen_id }}"
          name="contact[address]"
          class="ai-catering-form__input-{{ ai_gen_id }}"
        >
      </div>

      <div class="ai-catering-form__row-{{ ai_gen_id }}">
        <div class="ai-catering-form__field-{{ ai_gen_id }}">
          <label for="ai-catering-event-date-{{ ai_gen_id }}" class="ai-catering-form__label-{{ ai_gen_id }}">
            Event Date <span class="ai-catering-form__required-{{ ai_gen_id }}">*</span>
          </label>
          <input
            type="date"
            id="ai-catering-event-date-{{ ai_gen_id }}"
            name="contact[event_date]"
            class="ai-catering-form__input-{{ ai_gen_id }}"
            required
            aria-required="true"
          >
        </div>

        <div class="ai-catering-form__field-{{ ai_gen_id }}">
          <label for="ai-catering-event-type-{{ ai_gen_id }}" class="ai-catering-form__label-{{ ai_gen_id }}">
            Event Type <span class="ai-catering-form__required-{{ ai_gen_id }}">*</span>
          </label>
          <input
            type="text"
            id="ai-catering-event-type-{{ ai_gen_id }}"
            name="contact[event_type]"
            class="ai-catering-form__input-{{ ai_gen_id }}"
            placeholder="e.g., Wedding, Corporate Event, Birthday Party"
            required
            aria-required="true"
          >
        </div>
      </div>

      <div class="ai-catering-form__field-{{ ai_gen_id }}">
        <label for="ai-catering-guests-{{ ai_gen_id }}" class="ai-catering-form__label-{{ ai_gen_id }}">
          Number of Guests <span class="ai-catering-form__required-{{ ai_gen_id }}">*</span>
        </label>
        <input
          type="number"
          id="ai-catering-guests-{{ ai_gen_id }}"
          name="contact[number_of_guests]"
          class="ai-catering-form__input-{{ ai_gen_id }}"
          min="1"
          required
          aria-required="true"
        >
      </div>

      <div class="ai-catering-form__field-{{ ai_gen_id }}">
        <label for="ai-catering-message-{{ ai_gen_id }}" class="ai-catering-form__label-{{ ai_gen_id }}">
          Message / Additional Details
        </label>
        <textarea
          id="ai-catering-message-{{ ai_gen_id }}"
          name="contact[body]"
          class="ai-catering-form__textarea-{{ ai_gen_id }}"
          placeholder="Please provide any additional details about your catering needs..."
        ></textarea>
      </div>

      <button type="submit" class="ai-catering-form__button-{{ ai_gen_id }}">
        {{ block.settings.button_text }}
      </button>
    </div>
  {% endform %}
</catering-form-{{ ai_gen_id }}>

<script>
  (function() {
    class CateringForm{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        const form = this.querySelector('form');
        const successMessage = this.querySelector('#ai-catering-form-success-{{ ai_gen_id }}');
        
        if (successMessage) {
          successMessage.scrollIntoView({ behavior: 'smooth', block: 'center' });
          successMessage.setAttribute('role', 'status');
          successMessage.setAttribute('aria-live', 'polite');
        }
      }
    }

    customElements.define('catering-form-{{ ai_gen_id }}', CateringForm{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Catering request form",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading",
      "default": "Request Catering Services"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description",
      "default": "<p>Fill out the form below and we'll get back to you within 24 hours to discuss your catering needs.</p>"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text",
      "default": "Submit Catering Request"
    },
    {
      "type": "text",
      "id": "success_message",
      "label": "Success message",
      "default": "Thank you for your catering request! We'll be in touch soon."
    },
    {
      "type": "text",
      "id": "error_message",
      "label": "Error message",
      "default": "Please correct the errors below and try again."
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "range",
      "id": "form_padding",
      "label": "Form padding",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "default": 40
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Text alignment",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "left"
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "Heading size",
      "min": 20,
      "max": 48,
      "step": 2,
      "unit": "px",
      "default": 32
    },
    {
      "type": "range",
      "id": "description_size",
      "label": "Description size",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "default": "#f3f3f3"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text",
      "default": "#121212"
    },
    {
      "type": "color",
      "id": "input_background_color",
      "label": "Input background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "input_border_color",
      "label": "Input border",
      "default": "#cccccc"
    },
    {
      "type": "color",
      "id": "button_color",
      "label": "Button background",
      "default": "#121212"
    },
    {
      "type": "color",
      "id": "button_hover_color",
      "label": "Button hover background",
      "default": "#242833"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Button text",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "success_bg_color",
      "label": "Success background",
      "default": "#d4edda"
    },
    {
      "type": "color",
      "id": "success_text_color",
      "label": "Success text",
      "default": "#155724"
    },
    {
      "type": "color",
      "id": "error_bg_color",
      "label": "Error background",
      "default": "#f8d7da"
    },
    {
      "type": "color",
      "id": "error_color",
      "label": "Error text",
      "default": "#721c24"
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "range",
      "id": "border_radius",
      "label": "Form border radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 8
    },
    {
      "type": "range",
      "id": "input_border_radius",
      "label": "Input border radius",
      "min": 0,
      "max": 20,
      "step": 2,
      "unit": "px",
      "default": 4
    },
    {
      "type": "range",
      "id": "button_border_radius",
      "label": "Button border radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 4
    }
  ],
  "presets": [
    {
      "name": "Catering request form"
    }
  ]
}
{% endschema %}

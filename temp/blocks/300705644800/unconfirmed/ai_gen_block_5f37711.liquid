{% doc %}
  @prompt
    Create a custom catering request form section for the Events and Beverage Catering page. The form should include the following fields: Name, Email, Phone Number, Company Name, Company Address, Event Date, Event Type, Number of Guests, and a Message/Additional Details textarea. The form should have a submit button labeled "Submit Catering Request". Style it to look professional and match the store's theme. The form should submit via Shopify's native contact form action so submissions are received in the store's email.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-catering-form-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    margin: 0 auto;
    padding: {{ block.settings.form_padding }}px;
    background-color: {{ block.settings.background_color }};
    border-radius: {{ block.settings.border_radius }}px;
  }

  .ai-catering-form__heading-{{ ai_gen_id }} {
    margin: 0 0 12px;
    font-size: {{ block.settings.heading_size }}px;
    color: {{ block.settings.text_color }};
    text-align: {{ block.settings.text_alignment }};
  }

  .ai-catering-form__description-{{ ai_gen_id }} {
    margin: 0 0 32px;
    color: {{ block.settings.text_color }};
    opacity: 0.8;
    text-align: {{ block.settings.text_alignment }};
  }

  .ai-catering-form__form-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .ai-catering-form__row-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
  }

  @media screen and (max-width: 749px) {
    .ai-catering-form__row-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
    }
  }

  .ai-catering-form__field-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .ai-catering-form__label-{{ ai_gen_id }} {
    font-size: 14px;
    font-weight: 500;
    color: {{ block.settings.text_color }};
  }

  .ai-catering-form__label-{{ ai_gen_id }} .required {
    color: {{ block.settings.error_color }};
  }

  .ai-catering-form__input-{{ ai_gen_id }},
  .ai-catering-form__textarea-{{ ai_gen_id }},
  .ai-catering-form__select-{{ ai_gen_id }} {
    padding: 12px 16px;
    font-size: 16px;
    border: {{ block.settings.input_border_thickness }}px solid {{ block.settings.input_border_color }};
    border-radius: {{ block.settings.input_border_radius }}px;
    background-color: {{ block.settings.input_background_color }};
    color: {{ block.settings.text_color }};
    font-family: inherit;
  }

  .ai-catering-form__input-{{ ai_gen_id }}:focus,
  .ai-catering-form__textarea-{{ ai_gen_id }}:focus,
  .ai-catering-form__select-{{ ai_gen_id }}:focus {
    outline: 2px solid {{ block.settings.button_color }};
    outline-offset: 2px;
  }

  .ai-catering-form__textarea-{{ ai_gen_id }} {
    min-height: 120px;
    resize: vertical;
  }

  .ai-catering-form__button-{{ ai_gen_id }} {
    padding: 16px 32px;
    font-size: 16px;
    font-weight: 600;
    background-color: {{ block.settings.button_color }};
    color: {{ block.settings.button_text_color }};
    border: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    cursor: pointer;
    transition: background-color 0.3s ease;
    align-self: {{ block.settings.button_alignment }};
  }

  .ai-catering-form__button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_color }};
  }

  .ai-catering-form__success-{{ ai_gen_id }} {
    padding: 16px;
    background-color: {{ block.settings.success_bg_color }};
    color: {{ block.settings.success_text_color }};
    border-radius: {{ block.settings.input_border_radius }}px;
    margin-bottom: 20px;
    text-align: center;
  }

  .ai-catering-form__error-{{ ai_gen_id }} {
    padding: 16px;
    background-color: {{ block.settings.error_bg_color }};
    color: {{ block.settings.error_color }};
    border-radius: {{ block.settings.input_border_radius }}px;
    margin-bottom: 20px;
  }

  .ai-catering-form__error-list-{{ ai_gen_id }} {
    margin: 0;
    padding-left: 20px;
  }
{% endstyle %}

<catering-form-{{ ai_gen_id }} class="ai-catering-form-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  {% if block.settings.heading != blank %}
    <h2 class="ai-catering-form__heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
  {% endif %}

  {% if block.settings.description != blank %}
    <div class="ai-catering-form__description-{{ ai_gen_id }}">{{ block.settings.description }}</div>
  {% endif %}

  {%- form 'contact', id: 'catering-form-' | append: ai_gen_id -%}
    <input type="hidden" name="contact[form_type]" value="Catering Request">

    {%- if form.posted_successfully? -%}
      <div class="ai-catering-form__success-{{ ai_gen_id }}" id="ai-catering-form-success-{{ ai_gen_id }}">
        {{ block.settings.success_message }}
      </div>
    {%- endif -%}

    {%- if form.errors -%}
      <div class="ai-catering-form__error-{{ ai_gen_id }}" id="ai-catering-form-error-{{ ai_gen_id }}">
        <strong>Please correct the following errors:</strong>
        <ul class="ai-catering-form__error-list-{{ ai_gen_id }}">
          {%- for field in form.errors -%}
            <li>{{ field | capitalize | replace: '_', ' ' }}: {{ form.errors.messages[field] }}</li>
          {%- endfor -%}
        </ul>
      </div>
    {%- endif -%}

    <div class="ai-catering-form__form-{{ ai_gen_id }}">
      <div class="ai-catering-form__row-{{ ai_gen_id }}">
        <div class="ai-catering-form__field-{{ ai_gen_id }}">
          <label for="catering-name-{{ ai_gen_id }}" class="ai-catering-form__label-{{ ai_gen_id }}">
            Name <span class="required">*</span>
          </label>
          <input
            type="text"
            id="catering-name-{{ ai_gen_id }}"
            name="contact[name]"
            class="ai-catering-form__input-{{ ai_gen_id }}"
            value="{{ form.name }}"
            required
            aria-required="true"
            {% if form.errors contains 'name' %}
              aria-invalid="true"
              aria-describedby="ai-catering-form-error-{{ ai_gen_id }}"
            {% endif %}
          >
        </div>

        <div class="ai-catering-form__field-{{ ai_gen_id }}">
          <label for="catering-email-{{ ai_gen_id }}" class="ai-catering-form__label-{{ ai_gen_id }}">
            Email <span class="required">*</span>
          </label>
          <input
            type="email"
            id="catering-email-{{ ai_gen_id }}"
            name="contact[email]"
            class="ai-catering-form__input-{{ ai_gen_id }}"
            value="{{ form.email }}"
            required
            autocomplete="email"
            aria-required="true"
            {% if form.errors contains 'email' %}
              aria-invalid="true"
              aria-describedby="ai-catering-form-error-{{ ai_gen_id }}"
            {% endif %}
          >
        </div>
      </div>

      <div class="ai-catering-form__row-{{ ai_gen_id }}">
        <div class="ai-catering-form__field-{{ ai_gen_id }}">
          <label for="catering-phone-{{ ai_gen_id }}" class="ai-catering-form__label-{{ ai_gen_id }}">
            Phone number <span class="required">*</span>
          </label>
          <input
            type="tel"
            id="catering-phone-{{ ai_gen_id }}"
            name="contact[phone]"
            class="ai-catering-form__input-{{ ai_gen_id }}"
            value="{{ form.phone }}"
            required
            autocomplete="tel"
            aria-required="true"
            {% if form.errors contains 'phone' %}
              aria-invalid="true"
              aria-describedby="ai-catering-form-error-{{ ai_gen_id }}"
            {% endif %}
          >
        </div>

        <div class="ai-catering-form__field-{{ ai_gen_id }}">
          <label for="catering-company-{{ ai_gen_id }}" class="ai-catering-form__label-{{ ai_gen_id }}">
            Company name
          </label>
          <input
            type="text"
            id="catering-company-{{ ai_gen_id }}"
            name="contact[company]"
            class="ai-catering-form__input-{{ ai_gen_id }}"
            value="{{ form.company }}"
          >
        </div>
      </div>

      <div class="ai-catering-form__field-{{ ai_gen_id }}">
        <label for="catering-address-{{ ai_gen_id }}" class="ai-catering-form__label-{{ ai_gen_id }}">
          Company address
        </label>
        <input
          type="text"
          id="catering-address-{{ ai_gen_id }}"
          name="contact[company_address]"
          class="ai-catering-form__input-{{ ai_gen_id }}"
          value="{{ form.company_address }}"
        >
      </div>

      <div class="ai-catering-form__row-{{ ai_gen_id }}">
        <div class="ai-catering-form__field-{{ ai_gen_id }}">
          <label for="catering-event-date-{{ ai_gen_id }}" class="ai-catering-form__label-{{ ai_gen_id }}">
            Event date <span class="required">*</span>
          </label>
          <input
            type="text"
            id="catering-event-date-{{ ai_gen_id }}"
            name="contact[event_date]"
            class="ai-catering-form__input-{{ ai_gen_id }}"
            placeholder="MM/DD/YYYY"
            value="{{ form.event_date }}"
            required
            aria-required="true"
            {% if form.errors contains 'event_date' %}
              aria-invalid="true"
              aria-describedby="ai-catering-form-error-{{ ai_gen_id }}"
            {% endif %}
          >
        </div>

        <div class="ai-catering-form__field-{{ ai_gen_id }}">
          <label for="catering-event-type-{{ ai_gen_id }}" class="ai-catering-form__label-{{ ai_gen_id }}">
            Event type <span class="required">*</span>
          </label>
          <select
            id="catering-event-type-{{ ai_gen_id }}"
            name="contact[event_type]"
            class="ai-catering-form__select-{{ ai_gen_id }}"
            required
            aria-required="true"
            {% if form.errors contains 'event_type' %}
              aria-invalid="true"
              aria-describedby="ai-catering-form-error-{{ ai_gen_id }}"
            {% endif %}
          >
            <option value="">Select event type</option>
            <option value="Corporate Event" {% if form.event_type == 'Corporate Event' %}selected{% endif %}>Corporate Event</option>
            <option value="Wedding" {% if form.event_type == 'Wedding' %}selected{% endif %}>Wedding</option>
            <option value="Birthday Party" {% if form.event_type == 'Birthday Party' %}selected{% endif %}>Birthday Party</option>
            <option value="Holiday Party" {% if form.event_type == 'Holiday Party' %}selected{% endif %}>Holiday Party</option>
            <option value="Private Event" {% if form.event_type == 'Private Event' %}selected{% endif %}>Private Event</option>
            <option value="Other" {% if form.event_type == 'Other' %}selected{% endif %}>Other</option>
          </select>
        </div>
      </div>

      <div class="ai-catering-form__field-{{ ai_gen_id }}">
        <label for="catering-guests-{{ ai_gen_id }}" class="ai-catering-form__label-{{ ai_gen_id }}">
          Number of guests <span class="required">*</span>
        </label>
        <input
          type="number"
          id="catering-guests-{{ ai_gen_id }}"
          name="contact[number_of_guests]"
          class="ai-catering-form__input-{{ ai_gen_id }}"
          min="1"
          value="{{ form.number_of_guests }}"
          required
          aria-required="true"
          {% if form.errors contains 'number_of_guests' %}
            aria-invalid="true"
            aria-describedby="ai-catering-form-error-{{ ai_gen_id }}"
          {% endif %}
        >
      </div>

      <div class="ai-catering-form__field-{{ ai_gen_id }}">
        <label for="catering-message-{{ ai_gen_id }}" class="ai-catering-form__label-{{ ai_gen_id }}">
          Message / Additional details
        </label>
        <textarea
          id="catering-message-{{ ai_gen_id }}"
          name="contact[body]"
          class="ai-catering-form__textarea-{{ ai_gen_id }}"
          placeholder="Tell us more about your event..."
        >{{ form.body }}</textarea>
      </div>

      <button type="submit" class="ai-catering-form__button-{{ ai_gen_id }}">
        {{ block.settings.button_text }}
      </button>
    </div>
  {%- endform -%}
</catering-form-{{ ai_gen_id }}>

<script>
  (function() {
    class CateringForm{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        const form = this.querySelector('form');
        if (form && (form.querySelector('.ai-catering-form__success-{{ ai_gen_id }}') || form.querySelector('.ai-catering-form__error-{{ ai_gen_id }}'))) {
          form.scrollIntoView({ behavior: 'smooth', block: 'start' });
        }
      }
    }

    customElements.define('catering-form-{{ ai_gen_id }}', CateringForm{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Catering request form",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading",
      "default": "Request Catering Services"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description",
      "default": "<p>Fill out the form below and we'll get back to you within 24 hours to discuss your event needs.</p>"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text",
      "default": "Submit Catering Request"
    },
    {
      "type": "text",
      "id": "success_message",
      "label": "Success message",
      "default": "Thank you for your catering request! We'll be in touch soon."
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "range",
      "id": "form_padding",
      "label": "Form padding",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "default": 40
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Text alignment",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "left"
    },
    {
      "type": "select",
      "id": "button_alignment",
      "label": "Button alignment",
      "options": [
        {
          "value": "flex-start",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "flex-end",
          "label": "Right"
        }
      ],
      "default": "flex-start"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "default": "#f3f3f3"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text",
      "default": "#121212"
    },
    {
      "type": "color",
      "id": "input_background_color",
      "label": "Input background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "input_border_color",
      "label": "Input border",
      "default": "#cccccc"
    },
    {
      "type": "color",
      "id": "button_color",
      "label": "Button background",
      "default": "#121212"
    },
    {
      "type": "color",
      "id": "button_hover_color",
      "label": "Button hover background",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Button text",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "success_bg_color",
      "label": "Success background",
      "default": "#d4edda"
    },
    {
      "type": "color",
      "id": "success_text_color",
      "label": "Success text",
      "default": "#155724"
    },
    {
      "type": "color",
      "id": "error_bg_color",
      "label": "Error background",
      "default": "#f8d7da"
    },
    {
      "type": "color",
      "id": "error_color",
      "label": "Error text",
      "default": "#721c24"
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "Heading size",
      "min": 20,
      "max": 48,
      "step": 2,
      "unit": "px",
      "default": 32
    },
    {
      "type": "range",
      "id": "border_radius",
      "label": "Form border radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 8
    },
    {
      "type": "range",
      "id": "input_border_thickness",
      "label": "Input border thickness",
      "min": 0,
      "max": 4,
      "step": 1,
      "unit": "px",
      "default": 1
    },
    {
      "type": "range",
      "id": "input_border_radius",
      "label": "Input border radius",
      "min": 0,
      "max": 20,
      "step": 2,
      "unit": "px",
      "default": 4
    },
    {
      "type": "range",
      "id": "button_border_radius",
      "label": "Button border radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 0
    }
  ],
  "presets": [
    {
      "name": "Catering request form"
    }
  ]
}
{% endschema %}

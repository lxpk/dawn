{% doc %}
  @prompt
    Create a secondary navigation menu bar that appears above or below the existing header on desktop screens only. It should be a separate, full-width bar with its own menu link list that can be configured in theme settings.  Style it to complement the existing header with customizable background color, text color, and font size settings.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-secondary-nav-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    background-color: {{ block.settings.background_color }};
    border-bottom: 1px solid {{ block.settings.border_color }};
  }

  .ai-secondary-nav-container-{{ ai_gen_id }} {
    max-width: {{ settings.page_width }}px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .ai-secondary-nav-list-{{ ai_gen_id }} {
    display: flex;
    justify-content: {{ block.settings.menu_alignment }};
    align-items: center;
    gap: {{ block.settings.link_spacing }}px;
    list-style: none;
    margin: 0;
    padding: {{ block.settings.vertical_padding }}px 0;
    flex-wrap: wrap;
  }

  .ai-secondary-nav-item-{{ ai_gen_id }} {
    margin: 0;
  }

  .ai-secondary-nav-link-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    text-decoration: none;
    font-size: {{ block.settings.font_size }}px;
    font-weight: {{ block.settings.font_weight }};
    transition: color 0.2s ease;
    display: block;
    white-space: nowrap;
  }

  .ai-secondary-nav-link-{{ ai_gen_id }}:hover {
    color: {{ block.settings.text_hover_color }};
  }

  @media screen and (max-width: 749px) {
    .ai-secondary-nav-{{ ai_gen_id }} {
      display: none;
    }
  }
{% endstyle %}

<secondary-nav-{{ ai_gen_id }} class="ai-secondary-nav-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-secondary-nav-container-{{ ai_gen_id }}">
    <ul class="ai-secondary-nav-list-{{ ai_gen_id }}">
      {% for link in linklists[block.settings.menu].links %}
        <li class="ai-secondary-nav-item-{{ ai_gen_id }}">
          <a href="{{ link.url }}" class="ai-secondary-nav-link-{{ ai_gen_id }}">
            {{ link.title }}
          </a>
        </li>
      {% endfor %}
    </ul>
  </div>
</secondary-nav-{{ ai_gen_id }}>

<script>
  (function() {
    class SecondaryNav{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.setupAccessibility();
      }

      setupAccessibility() {
        const links = this.querySelectorAll('.ai-secondary-nav-link-{{ ai_gen_id }}');
        links.forEach(link => {
          link.setAttribute('role', 'menuitem');
        });

        const list = this.querySelector('.ai-secondary-nav-list-{{ ai_gen_id }}');
        if (list) {
          list.setAttribute('role', 'menubar');
        }
      }
    }

    customElements.define('secondary-nav-{{ ai_gen_id }}', SecondaryNav{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Secondary navigation",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Menu"
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "Menu",
      "default": "main-menu"
    },
    {
      "type": "select",
      "id": "menu_alignment",
      "label": "Menu alignment",
      "options": [
        {
          "value": "flex-start",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "flex-end",
          "label": "Right"
        }
      ],
      "default": "center"
    },
    {
      "type": "range",
      "id": "link_spacing",
      "label": "Link spacing",
      "min": 10,
      "max": 50,
      "step": 5,
      "unit": "px",
      "default": 30
    },
    {
      "type": "range",
      "id": "vertical_padding",
      "label": "Vertical padding",
      "min": 5,
      "max": 30,
      "step": 5,
      "unit": "px",
      "default": 15
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "default": "#f3f3f3"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text",
      "default": "#121212"
    },
    {
      "type": "color",
      "id": "text_hover_color",
      "label": "Text hover",
      "default": "#521e03"
    },
    {
      "type": "color",
      "id": "border_color",
      "label": "Border",
      "default": "#e0e0e0"
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "range",
      "id": "font_size",
      "label": "Font size",
      "min": 12,
      "max": 20,
      "step": 1,
      "unit": "px",
      "default": 14
    },
    {
      "type": "select",
      "id": "font_weight",
      "label": "Font weight",
      "options": [
        {
          "value": "400",
          "label": "Normal"
        },
        {
          "value": "500",
          "label": "Medium"
        },
        {
          "value": "600",
          "label": "Semi-bold"
        },
        {
          "value": "700",
          "label": "Bold"
        }
      ],
      "default": "400"
    }
  ],
  "presets": [
    {
      "name": "Secondary navigation"
    }
  ]
}
{% endschema %}

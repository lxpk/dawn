<script>
  function getGrid(funct) {
    document.getElementById('wl_function').value = funct;
    document.getElementById('wishlist').submit();
  }

  function getGRGrid() {
    document.getElementById('gr_quantity').value = document.getElementById('quantity').value;
    document.getElementById('gift_reg').submit();
  }

  function swapImage(ID) {
    var thumbs = { option1: {}, option2: {}, option3: {} };
    var fulls  = { option1: {}, option2: {}, option3: {} };
    var s = document.getElementById(ID);
    var selectedOption = s.options[s.selectedIndex].value.toLowerCase();
    var o1 = document.getElementById('option1');
    var selectedOption1 = o1.options[o1.selectedIndex].value.toLowerCase();
    var thumb = 'clearpixel.gif';
    var full  = '';
    if (selectedOption in thumbs[ID]) { thumb = thumbs[ID][selectedOption]; }
    if (selectedOption in fulls[ID])  { full  = fulls[ID][selectedOption]; }
    if (selectedOption1 in thumbs['option1']) { thumb = thumbs['option1'][selectedOption1]; }
    if (selectedOption1 in fulls['option1'])  { full  = fulls['option1'][selectedOption1]; }
    document.getElementById('thumbnail').src = 'images/thumbnails/' + thumb;
    document.getElementById('fullsize').src  = 'images/fullsize/' + full;
  }

  function showAccessPane(showID) {
  // Hide all panes
  ['none_pane','kegerator_pane','jockeybox_pane'].forEach(function(id) {
    var el = document.getElementById(id);
    if (el) el.style.display = 'none';
  });

  // Hide/show the image box and exchange/cups cells
  var image_cell    = document.getElementById('keg_supp_accessories_image_cell');
  var exchange_cell = document.getElementById('keg_supp_accessories_exchange_cell');
  var cups_cell     = document.getElementById('keg_supp_accessories_cups_cell');

  if (showID === 'none') {
    if (image_cell)    image_cell.style.display    = 'none';
    if (exchange_cell) exchange_cell.style.display = 'block';
    if (cups_cell)     cups_cell.style.display     = 'block';
  } else {
    if (image_cell)    image_cell.style.display    = 'block';
    if (exchange_cell) exchange_cell.style.display = 'none';
    if (cups_cell)     cups_cell.style.display     = 'none';
  }

  // Show selected pane
  var showPane = document.getElementById(showID + '_pane');
  if (showPane) showPane.style.display = 'block';

  changeBGimage(showID);
}

function changeBGimage(showID) {
  var image_div = document.getElementById('keg_accessories_image_div');
  if (!image_div) return;
  var images = {
    kegerator: 'generic_kegerator.jpg',
    jockeybox: 'generic_jockeybox.jpg'
  };
  if (images[showID]) {
    image_div.style.backgroundImage = "url('{{ 'generic_kegerator.jpg' | asset_url }}')";
    if (showID === 'jockeybox') {
      image_div.style.backgroundImage = "url('{{ 'generic_jockeybox.jpg' | asset_url }}')";
    }
  } else {
    image_div.style.backgroundImage = 'none';
  }
}

  function numbersonly(e) {
    var unicode = e.charCode ? e.charCode : e.keyCode;
    if (unicode !== 8 && (unicode < 48 || unicode > 57)) { return false; }
  }

  var visible_price_el  = null;
  var visible_retail_el = null;
  function update_displayed_price() {
    var unit_el = document.getElementById('alt_unit_select');
    var unit    = unit_el.options[unit_el.selectedIndex].value;
    if (visible_price_el) {
      visible_price_el.style.visibility = 'hidden';
      visible_price_el.style.display    = 'none';
    }
    var price_el = document.getElementById(unit + '_display_price');
    visible_price_el = price_el;
    price_el.style.visibility = 'visible';
    price_el.style.display    = 'inline';
    if (visible_retail_el) {
      visible_retail_el.style.visibility = 'hidden';
    }
  }

  function createNewInput(inp_name, inp_value) {
    var form    = document.getElementById('cart_form');
    var new_inp = document.createElement('input');
    new_inp.setAttribute('type',  'hidden');
    new_inp.setAttribute('name',  inp_name);
    new_inp.setAttribute('value', inp_value);
    form.appendChild(new_inp);
  }

  function add_accessories() {
  //  var form = document.getElementById('cart_form');
  //  if (!qtyCheck(form)) { return false; }
    var buy_kegs = document.getElementById('quantity').value;
    createNewInput('item[KEG-DEP][quantity]', buy_kegs);
    var return_kegs = 0;
    var kr = document.getElementById('kr_exch_qty');
    var ex = document.getElementById('exch_qty');
    if (kr && kr.value > 0)      { return_kegs = kr.value; }
    else if (ex && ex.value > 0) { return_kegs = ex.value; }
    if (return_kegs > 0) { createNewInput('item[KEG-RET][quantity]', return_kegs); }
    var cup_map = [
      { cb: 'kr_add_cups', sel: 'kr_cups_qty' },
      { cb: 'jb_add_cups', sel: 'jb_cups_qty' },
      { cb: 'kt_add_cups', sel: 'kt_cups_qty' },
      { cb: 'add_cups',    sel: 'cups_qty'    }
    ];
    cup_map.forEach(function(c) {
      var cb = document.getElementById(c.cb);
      if (cb && cb.checked) {
        var sel = document.getElementById(c.sel);
        createNewInput('item[' + sel.options[sel.selectedIndex].value + '][quantity]', 1);
      }
    });
    var acc_el = document.querySelector('input[name="accessories"]:checked');
    var acc_selected = acc_el ? acc_el.value : 'none';
    if (acc_selected === 'none') { return true; }
    if (acc_selected === 'kegerator') {
      var kr_co2 = document.getElementById('kr_addl_co2');
      if (kr_co2 && kr_co2.checked) {
        var addl_co2_qty = document.getElementById('kr_addl_co2_qty').value;
        if (!isNaN(parseFloat(addl_co2_qty)) && isFinite(addl_co2_qty) && addl_co2_qty > 0) {
          var co2_size_el = document.querySelector('input[name="kr_addl_co2_size"]:checked');
          var co2_size    = co2_size_el ? co2_size_el.value : '';
          if (co2_size === '2.5') { createNewInput('item[MK19][quantity]', addl_co2_qty); }
          else if (co2_size === '5')  { createNewInput('item[MK5][quantity]',  addl_co2_qty); }
          else if (co2_size === '20') { createNewInput('item[MK18][quantity]', addl_co2_qty); }
        }
        createNewInput('item[AIRTANK DEPOSIT][quantity]', addl_co2_qty);
        var ret_cart = document.getElementById('kr_co2_exch_qty');
        if (ret_cart && ret_cart.value > 0) { createNewInput('item[AIRTANK-RET][quantity]', ret_cart.value); }
      }
      var coupler_el = document.querySelector('input[name="kegerator_coupler"]:checked');
      var coupler    = coupler_el ? coupler_el.value : '';
      if (coupler === 'rental')        { createNewInput('item[MM7485R][quantity]', 1); createNewInput('item[MM7485D][quantity]', 1); }
      else if (coupler === 'purchase') { createNewInput('item[MM7485E][quantity]', 1); }
      var line_clean = document.getElementById('kr_line_clean');
      if (line_clean && line_clean.checked) {
        createNewInput('item[SERV001][quantity]', document.getElementById('kr_line_qty').value);
      }
    }
    else if (acc_selected === 'jockeybox') {
      var jb_deposit = 0;
      var jb_el = document.querySelector('input[name="rent_jb"]:checked');
      var jb    = jb_el ? jb_el.value : '';
      if (jb === 'jbr1')      { createNewInput('item[MK02][quantity]', 1); jb_deposit++; }
      else if (jb === 'jbr2') { createNewInput('item[MK03][quantity]', 1); jb_deposit++; }
      if (jb_deposit > 0) { createNewInput('item[JOCKEY-BOX-DEPOSIT][quantity]', jb_deposit); }
      var jb_ice = document.getElementById('jb_ice');
      if (jb_ice && jb_ice.checked) {
        if (jb_ice.value === '1')      { createNewInput('item[CO013|7LB][quantity]', 1); }
        else if (jb_ice.value === '6') { createNewInput('item[CO013|6 PK][quantity]', 1); }
      }
      var jb_addl = document.getElementById('jb_addl_ice');
      if (jb_addl && jb_addl.checked) {
        var addl_ice = document.getElementById('jb_addl_ice_qty').value;
        if (!isNaN(parseFloat(addl_ice)) && isFinite(addl_ice) && addl_ice > 0) {
          createNewInput('item[CO013|7LB][quantity]', addl_ice);
        }
      }
    }
    else if (acc_selected === 'tub') {
      var kt_deposit = 0;
      var rent_tub = document.getElementById('rent_kegtub');
      if (rent_tub && rent_tub.checked) { createNewInput('item[MK55][quantity]', 1); kt_deposit++; }
      var buy_tub = document.getElementById('buy_kegtub');
      if (buy_tub && buy_tub.checked)   { createNewInput('item[MK56][quantity]', 1); }
      var rent_pump = document.getElementById('rent_pump');
      if (rent_pump && rent_pump.checked) { createNewInput('item[MM7509R][quantity]', 1); createNewInput('item[MM7509D][quantity]', 1); }
      var buy_pump = document.getElementById('buy_pump');
      if (buy_pump && buy_pump.checked)   { createNewInput('item[MM7509E][quantity]', 1); }
      if (kt_deposit > 0) { createNewInput('item[TUB DEPOSIT][quantity]', kt_deposit); }
      var tub_ice = document.getElementById('tub_ice');
      if (tub_ice && tub_ice.checked) {
        var tub_ice_qty = document.getElementById('tub_addl_ice_qty').value;
        if (!isNaN(parseFloat(tub_ice_qty)) && isFinite(tub_ice_qty) && tub_ice_qty > 0) {
          createNewInput('item[CO013|7LB][quantity]', tub_ice_qty);
        }
      }
    }
    return true;
  }

  function add_deposits() {
    var form = document.getElementById('cart_form');
    return qtyCheck(form) ? true : false;
  }

  function flipViz(trigger, target) {
    var cb = document.getElementById(trigger);
    var el = document.getElementById(target);
    if (cb && cb.checked) {
      el.style.visibility = 'visible';
      el.style.display    = 'block';
    } else {
      el.style.visibility = 'hidden';
      el.style.display    = 'none';
    }
  }
</script>
